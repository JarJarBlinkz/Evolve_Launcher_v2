<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="6dp"
    android:background="@drawable/dialog_background"
    android:gravity="center_horizontal">

    <!-- Title - Smaller -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 Device Information"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <!-- ScrollView for content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Storage Card - Compact -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💾 Storage Information"
                        android:textColor="#6B8EFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <!-- Internal Storage -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="1dp">

                        <TextView
                            android:layout_width="55dp"
                            android:layout_height="wrap_content"
                            android:text="Internal:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/txtInternalStorage"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/internalStorageProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginBottom="2dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#6B8EFF"
                        android:backgroundTint="#333333" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="2dp">

                        <TextView
                            android:id="@+id/txtInternalUsed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Used: 0B"
                            android:textColor="#FF6B6B"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/txtInternalFree"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Free: 0B"
                            android:textColor="#4CAF50"
                            android:textSize="8sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/txtInternalTotal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total: 0B"
                            android:textColor="#6B8EFF"
                            android:textSize="8sp"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- System Information Card - Compact Grid -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📱 System Information"
                        android:textColor="#6B8EFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="5">

                        <!-- Row 1 -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Model:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtDeviceModel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 2 -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Manufacturer:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtManufacturer"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 3 -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Android:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtAndroidVersion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 4 -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="API Level:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtApiLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 5 -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Build:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtBuildNumber"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hardware Information Card - Compact Grid -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚙️ Hardware Information"
                        android:textColor="#6B8EFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="5">

                        <!-- Row 1 - Total RAM -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Total RAM:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtTotalRAM"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 2 - Available RAM -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Available:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtAvailableRAM"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 3 - Processor -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Processor:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtProcessor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 4 - CPU Cores -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="CPU Cores:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtCpuCores"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 5 - Resolution -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Resolution:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtResolution"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </GridLayout>

                    <!-- Density on its own line since it's longer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:layout_width="55dp"
                            android:layout_height="wrap_content"
                            android:text="Density:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/txtDensity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </LinearLayout>

                    <!-- RAM Usage Bar -->
                    <ProgressBar
                        android:id="@+id/ramProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="2dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#FF9800"
                        android:backgroundTint="#333333" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtRAMUsed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Used: 0B"
                            android:textColor="#FF6B6B"
                            android:textSize="8sp" />

                        <TextView
                            android:id="@+id/txtRAMFree"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Free: 0B"
                            android:textColor="#4CAF50"
                            android:textSize="8sp"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/txtRAMTotal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total: 0B"
                            android:textColor="#FF9800"
                            android:textSize="8sp"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Network Information Card - Compact -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🌐 Network Information"
                        android:textColor="#6B8EFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="5">

                        <!-- Row 1 - IP Address -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="IP Address:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtDeviceIP"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 2 - MAC Address -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="MAC Address:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtMacAddress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 3 - Wi-Fi SSID -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Wi-Fi Network:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtWifiSSID"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 4 - Signal Strength -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Signal:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtSignalStrength"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 5 - Link Speed -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Link Speed:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtLinkSpeed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Battery Information Card - Compact -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔋 Battery Information"
                        android:textColor="#6B8EFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="5">

                        <!-- Row 1 - Battery Level -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Level:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtBatteryLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 2 - Status -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Status:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtBatteryStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 3 - Temperature -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Temperature:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtBatteryTemp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 4 - Health -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Health:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtBatteryHealth"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <!-- Row 5 - Voltage -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Voltage:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginEnd="2dp" />

                        <TextView
                            android:id="@+id/txtBatteryVoltage"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </GridLayout>

                    <!-- Technology on its own line -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:layout_width="55dp"
                            android:layout_height="wrap_content"
                            android:text="Tech:"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/txtBatteryTech"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Loading..."
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- App Information Card - Minimal -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 App:"
                        android:textColor="#6B8EFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/txtAppVersion"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Loading..."
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/txtPackageName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#808080"
                        android:textSize="8sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Back Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="4dp"
        android:backgroundTint="#333333"
        android:text="← Back to Settings"
        android:textColor="#FFFFFF"
        android:textSize="10sp" />

</LinearLayout>