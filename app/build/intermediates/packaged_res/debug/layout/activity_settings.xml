<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/dialog_background">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙️ VR Launcher Settings"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="10dp"
        android:background="#1E1E1E" />

    <!-- 3-Column Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="10dp"
        android:weightSum="3">

        <!-- COLUMN 1: SYSTEM & UPDATES -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="5dp">

            <!-- SYSTEM -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SYSTEM"
                android:textColor="#6B8EFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✏️ Edit Mode"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchEditMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="#333333"
                    app:thumbTint="#6B8EFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📁 Show Categories"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="#333333"
                    app:thumbTint="#6B8EFF" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnManageCategories"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="6dp"
                android:backgroundTint="#4CAF50"
                android:text="📂 Manage Categories"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDeviceInfo"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="6dp"
                android:backgroundTint="#9C27B0"
                android:text="📊 Device Info"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🚀 Auto-start"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="#333333"
                    app:thumbTint="#6B8EFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔄 Auto-Restart"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/autoRestartSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:trackTint="#333333"
                        app:thumbTint="#6B8EFF" />
                </LinearLayout>

                <TextView
                    android:id="@+id/autoRestartStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_restart_enabled"
                    android:textColor="#4CAF50"
                    android:textSize="10sp"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginVertical="6dp" />

            <!-- UPDATES -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="UPDATES"
                android:textColor="#6B8EFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Version"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/txtCurrentVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0.0"
                    android:textColor="#6B8EFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔄 Auto-check"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutoUpdate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="#333333"
                    app:thumbTint="#6B8EFF" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCheckUpdates"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="🔎 Check Updates"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:backgroundTint="#2196F3" />

        </LinearLayout>

        <!-- COLUMN 2: APPEARANCE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="5dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="APPEARANCE"
                android:textColor="#6B8EFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Icon Size -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📏 Icon Size"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <SeekBar
                android:id="@+id/seekIconSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/txtIconSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="110dp"
                android:textColor="#6B8EFF"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <!-- Background Opacity -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎨 Background Opacity"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="2dp" />

            <SeekBar
                android:id="@+id/seekBgOpacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100" />

            <TextView
                android:id="@+id/txtBgOpacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="#6B8EFF"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <!-- Background Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="3">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBgBuiltin"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="#6B8EFF"
                    android:text="Built-in"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBgCustom"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="1dp"
                    android:backgroundTint="#4CAF50"
                    android:text="Custom"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBgDefault"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:backgroundTint="#333333"
                    android:text="Default"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- COLUMN 3: DATA & BACKUP -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="5dp">

            <!-- DATA & STATS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="DATA &amp; STATS"
                android:textColor="#6B8EFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnUsageAccess"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="6dp"
                android:backgroundTint="#F44336"
                android:text="🔓 Grant Usage Access"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGameStats"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#9C27B0"
                android:text="🏆 Game Stats"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="6dp"
                android:background="#333333" />

            <!-- BACKUP & RESTORE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="BACKUP &amp; RESTORE"
                android:textColor="#6B8EFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Save and restore all launcher settings"
                android:textColor="#AAAAAA"
                android:textSize="10sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnBackup"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#4CAF50"
                    android:text="💾 Backup"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btnRestore"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FF9800"
                    android:text="📥 Restore"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E1E"
        android:padding="8dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:backgroundTint="#333333"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>