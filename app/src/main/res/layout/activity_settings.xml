<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/dialog_background">

    <!-- Fixed Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙️ VR Launcher Settings"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="12dp"
        android:background="#1E1E1E" />

    <!-- Scrollable 2-Column Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:weightSum="2">

            <!-- ==================== LEFT COLUMN ==================== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="4dp">

                <!-- SYSTEM Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2A2A2A"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SYSTEM"
                        android:textColor="#6B8EFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnDeviceInfo"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginBottom="6dp"
                        android:backgroundTint="#9C27B0"
                        android:text="📊 Device Info"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#1E1E1E"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🚀 Auto-start"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchAutoStart"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:trackTint="#333333"
                            app:thumbTint="#6B8EFF" />
                    </LinearLayout>
                </LinearLayout>

                <!-- UPDATES Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2A2A2A"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="UPDATES"
                        android:textColor="#6B8EFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#1E1E1E"
                        android:padding="8dp"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Version"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtCurrentVersion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.0.0"
                            android:textColor="#6B8EFF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#1E1E1E"
                        android:padding="8dp"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔄 Auto-check"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchAutoUpdate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:trackTint="#333333"
                            app:thumbTint="#6B8EFF" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnCheckUpdates"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:text="🔎 Check Now"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#2196F3" />
                </LinearLayout>

                <!-- APPEARANCE Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2A2A2A"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="APPEARANCE"
                        android:textColor="#6B8EFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#1E1E1E"
                        android:padding="8dp"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="✏️ Edit Mode"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchEditMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:trackTint="#333333"
                            app:thumbTint="#6B8EFF" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#1E1E1E"
                        android:padding="8dp"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🏷️ Categories"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchCategories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:trackTint="#333333"
                            app:thumbTint="#6B8EFF" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnManageCategories"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:backgroundTint="#FF9800"
                        android:text="📁 Manage"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <!-- Icon Size -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#1E1E1E"
                        android:padding="8dp"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📐 Icon Size"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="80"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp" />

                            <SeekBar
                                android:id="@+id/seekIconSize"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="6dp"
                                android:max="100"
                                android:progress="50" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="140"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtIconSize"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="110dp"
                            android:textColor="#6B8EFF"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Background Opacity -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#1E1E1E"
                        android:padding="8dp"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🎨 Opacity"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp" />

                            <SeekBar
                                android:id="@+id/seekBgOpacity"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="6dp"
                                android:max="100"
                                android:progress="100" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtBgOpacity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="100%"
                            android:textColor="#6B8EFF"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Background Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:weightSum="3">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnBgBuiltin"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="2dp"
                            android:backgroundTint="#6B8EFF"
                            android:text="Built-in"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnBgCustom"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="1dp"
                            android:backgroundTint="#4CAF50"
                            android:text="Custom"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnBgDefault"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginStart="2dp"
                            android:backgroundTint="#333333"
                            android:text="Default"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- ==================== RIGHT COLUMN ==================== -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="4dp">

                <!-- DATA & STATS Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2A2A2A"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DATA &amp; STATS"
                        android:textColor="#6B8EFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnUsageAccess"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:backgroundTint="#F44336"
                        android:text="🔓 Usage Access"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnGameStats"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:backgroundTint="#9C27B0"
                        android:text="🏆 Game Stats"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- BACKUP & RESTORE Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2A2A2A"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BACKUP &amp; RESTORE"
                        android:textColor="#6B8EFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Save and restore launcher settings"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnBackup"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:backgroundTint="#4CAF50"
                            android:text="💾 Backup"
                            android:textSize="11sp" />

                        <Button
                            android:id="@+id/btnRestore"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:backgroundTint="#FF9800"
                            android:text="📥 Restore"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- SPACE FOR MORE Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2A2A2A"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ADD MORE OPTIONS"
                        android:textColor="#6B8EFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#1E1E1E"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Space ready for\nnew features!"
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Fixed Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E1E"
        android:padding="8dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:backgroundTint="#333333"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>