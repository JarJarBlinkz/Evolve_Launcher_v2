<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="#333333"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cover Image -->
        <ImageView
            android:id="@+id/imgGameCover"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="#2A2A2A"
            android:contentDescription="Game cover" />

        <!-- Card Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- App Name -->
            <TextView
                android:id="@+id/txtAppName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Beat Saber"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="3dp" />

            <!-- Version with Label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Installed: "
                    android:textColor="#888888"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtBuildVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v463+2.8.0"
                    android:textColor="#FFA500"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Type Badge (moved here) -->
            <TextView
                android:id="@+id/txtType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/type_badge_background"
                android:layout_marginBottom="6dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginVertical="4dp" />

            <!-- Playtime (moved here) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time Played: "
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtPlaytime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2h 30m"
                    android:textColor="#6B8EFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Percentage (moved here) -->
            <TextView
                android:id="@+id/txtPercentage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rank #1 (25%)"
                android:textColor="#4CAF50"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Dates -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Installed on: "
                    android:textColor="#888888"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/txtInstallDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024/01/01"
                    android:textColor="#00FF00"
                    android:textSize="9sp"
                    android:maxLines="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last updated: "
                    android:textColor="#888888"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/txtUpdateDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024/01/15"
                    android:textColor="#00FF00"
                    android:textSize="9sp"
                    android:maxLines="1" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>