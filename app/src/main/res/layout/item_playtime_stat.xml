<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="6dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:weightSum="10">

        <!-- App Name - 25% (more space for app name) -->
        <TextView
            android:id="@+id/txtAppName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.5"
            android:text="App Name"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Version - 20% -->
        <TextView
            android:id="@+id/txtBuildVersion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.0"
            android:text="v463+2.8.0"
            android:textColor="#FFA500"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingHorizontal="4dp" />

        <!-- Playtime - 12% -->
        <TextView
            android:id="@+id/txtPlaytime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="2h30m"
            android:textColor="#6B8EFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="end"
            android:maxLines="1"
            android:paddingHorizontal="2dp" />

        <!-- Percentage - 8% -->
        <TextView
            android:id="@+id/txtPercentage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="25%"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="1" />

        <!-- Install Date - 12% -->
        <TextView
            android:id="@+id/txtInstallDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="24-01-01"
            android:textColor="#00FF00"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:paddingHorizontal="2dp" />

        <!-- Update Date - 12% -->
        <TextView
            android:id="@+id/txtUpdateDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="24-01-01"
            android:textColor="#00FF00"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:paddingHorizontal="2dp" />

        <!-- Type Badge - 11% (moved to end) -->
        <TextView
            android:id="@+id/txtType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.1"
            android:text="Store"
            android:textSize="11sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"
            android:background="#33000000"
            android:layout_marginStart="2dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>