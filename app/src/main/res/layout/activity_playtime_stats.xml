<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="12dp">

    <!-- Header with icon and title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_vr_headset"
            android:tint="#6B8EFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Playtime Statistics"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnResetStats"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_delete"
            android:tint="#FF6B6B"
            android:padding="4dp" />

        <ImageView
            android:id="@+id/btnRefresh"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_refresh"
            android:tint="#6B8EFF"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Permission Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/permissionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#332222"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:src="@drawable/ic_settings"
                android:tint="#FF6B6B" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Permission Required"
                android:textColor="#FF6B6B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="To track playtime, VR Launcher needs usage access permission.\n\nIf you've already run the ADB command, try restarting the app."
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGrantPermission"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="#6B8EFF"
                android:text="Open Settings"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Time Range Selector -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabTimeRange"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginBottom="8dp"
        app:tabBackground="@drawable/category_button_background"
        app:tabIndicatorColor="#6B8EFF"
        app:tabIndicatorHeight="2dp"
        app:tabSelectedTextColor="#6B8EFF"
        app:tabTextColor="#FFFFFF"
        app:tabMode="fixed"
        app:tabGravity="fill">

        <com.google.android.material.tabs.TabItem android:text="Today" />
        <com.google.android.material.tabs.TabItem android:text="Week" />
        <com.google.android.material.tabs.TabItem android:text="Month" />
        <com.google.android.material.tabs.TabItem android:text="All Time" />

    </com.google.android.material.tabs.TabLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Time Only Shows Stats Since Last Reset"
            android:textColor="#FF0000"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Summary Stats Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">



        <!-- Total Playtime -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textColor="#808080"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtTotalPlaytime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0h"
                    android:textColor="#6B8EFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Most Played -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Most Played"
                    android:textColor="#808080"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtMostPlayed"
                    android:layout_width="93dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="None"
                    android:textColor="#4CAF50"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Games Count -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Games"
                    android:textColor="#808080"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/txtGameCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FF9800"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Currently Playing Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/currentlyPlayingCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#1E5E1E"
        app:cardCornerRadius="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_play"
                android:tint="#4CAF50" />

            <TextView
                android:id="@+id/txtCurrentlyPlaying"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Currently Playing: "
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtCurrentPlaytime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0m"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Playtime List Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp">

        <!-- Playtime List Header - Matching the single line item layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp"
            android:weightSum="10">

            <!-- Playtime List Header - Matching the updated single line item layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="8dp"
                android:weightSum="10"
                android:background="#1A1A1A">

                <!-- App / Game - 25% (matches txtAppName weight 2.5) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:text="App / Game"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Version - 20% (matches txtBuildVersion weight 2.0) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.0"
                    android:text="Current Version"
                    android:textColor="#FFA500"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:paddingHorizontal="4dp"
                    android:ellipsize="end" />

                <!-- Playtime - 12% (matches txtPlaytime weight 1.2) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="Playtime"
                    android:textColor="#6B8EFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:maxLines="1"
                    android:paddingHorizontal="2dp"
                    android:ellipsize="end" />

                <!-- Percentage - 8% (matches txtPercentage weight 0.8) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.8"
                    android:text="%"
                    android:textColor="#4CAF50"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="1" />

                <!-- First Installed - 12% (matches txtInstallDate weight 1.2) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="Installed"
                    android:textColor="#808080"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="1"
                    android:paddingHorizontal="2dp"
                    android:ellipsize="end" />

                <!-- Last Updated - 12% (matches txtUpdateDate weight 1.2) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="Updated"
                    android:textColor="#808080"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="1"
                    android:paddingHorizontal="2dp"
                    android:ellipsize="end" />

                <!-- Type - 11% (matches txtType weight 1.1, moved to end) -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.1"
                    android:text="Type"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="2dp" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Type"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Version"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

    <!-- Playtime RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playtimeList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <!-- Footer -->
    <TextView
        android:id="@+id/txtLastUpdated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last updated: just now"
        android:textColor="#808080"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginTop="8dp" />

    <!-- Back Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:backgroundTint="#333333"
        android:text="← Back"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

</LinearLayout>